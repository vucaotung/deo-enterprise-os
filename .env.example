# ============================================================
# Dẹo Enterprise OS — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# PostgreSQL
POSTGRES_DB=deo_os
POSTGRES_USER=deo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_URL=redis://redis:6379

# API
NODE_ENV=production
PORT=3001
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_HERE
CORS_ORIGIN=https://dash.enterpriseos.bond

# Cloudflare Tunnel
TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE

# Domain
DOMAIN=enterpriseos.bond

# Backoffice / n8n integration
BACKOFFICE_N8N_WEBHOOK_URL=
BACKOFFICE_N8N_API_KEY=
BACKOFFICE_CALLBACK_URL=
BACKOFFICE_CALLBACK_TOKEN=
BACKOFFICE_GOOGLE_DRIVE_ROOT_NAME=Deo Workspace
