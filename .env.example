# ============================================================
# Dẹo Enterprise OS — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# PostgreSQL
POSTGRES_DB=deo_os
POSTGRES_USER=deo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_URL=redis://redis:6379

# API
NODE_ENV=production
PORT=3001
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_HERE
CORS_ORIGIN=https://dash.enterpriseos.bond

# Cloudflare Tunnel
TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE

# Domain
DOMAIN=enterpriseos.bond

# ── 2nd Brain / Obsidian ──────────────────────────────────
BRAIN_VAULT_PATH=/opt/deo-brain/vault
BRAIN_GIT_REPO=git@github.com:vucaotung/deo-brain-vault.git
GIT_EMAIL=vucaotung@gmail.com
GIT_NAME=Tung Vu Ca
BRAIN_CHUNK_SIZE=500
BRAIN_CHUNK_OVERLAP=50

# ChromaDB (vector store)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=CHANGE_ME_CHROMA_SECRET
CHROMA_COLLECTION=deo_brain

# Google Drive
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_ROOT_FOLDER_NAME=DEO-OS

# Embeddings (OpenAI)
OPENAI_API_KEY=
BRAIN_EMBED_MODEL=text-embedding-3-small

# Internal API token (cho cron jobs gọi API)
INTERNAL_TOKEN=CHANGE_ME_INTERNAL_SECRET_TOKEN

# API base (cho sync scripts)
API_BASE_URL=http://localhost:3001

# ── Grafana / Loki monitoring ──────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_ROOT_URL=https://grafana.enterpriseos.bond

# ── Admin seed (used once on first deploy by migrate.ts) ──
ADMIN_EMAIL=admin@enterpriseos.bond
ADMIN_INITIAL_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── Frontend URL (used in invite emails) ──
FRONTEND_URL=https://dash.enterpriseos.bond

# ── SMTP for invite emails (optional; logs to stdout if blank) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@enterpriseos.bond

