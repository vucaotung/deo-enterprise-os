NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://user:password@localhost:5432/deo
REDIS_URL=redis://localhost:6379

JWT_SECRET=your-secret-key-change-this

CORS_ORIGIN=http://localhost:3000

# ─── GoClaw Integration ───────────────────────────────────────
# Token này GoClaw gửi trong header X-Service-Token khi gọi /mcp/* và /internal/hooks/*
GOCLAW_SERVICE_TOKEN=goclaw_svc_change_this

# API key tùy chọn cho MCP clients khác (Bearer token)
MCP_API_KEY=mcp_api_key_change_this

# URL GoClaw đang chạy (để EOS gọi ngược lại nếu cần)
GOCLAW_BASE_URL=http://localhost:18790
GOCLAW_GATEWAY_TOKEN=goclaw_gw_change_this

# Telegram bots
TELEGRAM_BOT_MAIN=
TELEGRAM_BOT_ADMIN=
TELEGRAM_BOT_PHAPCHE=
TELEGRAM_BOT_KETOAN=
TELEGRAM_BOT_DIEUPHOI=
